# .env.example — copy this file to .env and fill in your values.
# The .env file is gitignored and never committed.
# This file IS committed as a template for new developers.

# ------------------------------------------------------------------
# Database
# ------------------------------------------------------------------
# SQLite (development default — no further setup needed):
DATABASE_URL=sqlite:///./graph.db

# PostgreSQL (production):
# DATABASE_URL=postgresql://tracer_user:your_password@localhost:5432/tracer_db

# ------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-deployment
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------
# Development — allow all origins:
CORS_ORIGINS=*

# Production — comma-separated list of allowed origins:
# CORS_ORIGINS=https://yourapp.com,https://admin.yourapp.com

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=false
APP_NAME=Tracer Graph API
APP_VERSION=0.1.0

# ------------------------------------------------------------------
# Admin credentials (single-user mode)
# ------------------------------------------------------------------
ADMIN_USERNAME=admin
# Plain password for development only:
ADMIN_PASSWORD=change-me
# For production, generate a bcrypt hash:
# python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('yourpassword'))"
# Then set:
# ADMIN_PASSWORD_HASH=<bcrypt hash>
